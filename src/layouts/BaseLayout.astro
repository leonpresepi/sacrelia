---
// Font self-hosted (Cormorant Garamond) — solo i pesi usati: 400 e 500.
import '@fontsource/cormorant-garamond/400.css';
import '@fontsource/cormorant-garamond/500.css';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl, useTranslations, localizePath } from '../i18n/utils';
import { languages } from '../i18n/ui';

interface Props {
  title: string;
  description: string;
  /** Path "neutro" della pagina (senza prefisso lingua), es. '/collection' o '/'. */
  path?: string;
  /** True per pagine con hero scuro: header trasparente sovrapposto. */
  overlayHeader?: boolean;
  /** Immagine di anteprima social (og:image). URL assoluto (es. copertina Sanity) o path locale.
   *  Se assente, usa l'immagine di brand di default. */
  image?: string;
}

const { title, description, path = '/', overlayHeader = false, image } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const siteName = 'Sacrelia';
const fullTitle = title ? `${title} — ${siteName}` : siteName;
const canonical = new URL(localizePath(path, lang), Astro.site);

// ⚠️ SOFT LAUNCH: noindex temporaneo finché i contenuti non sono pronti (sito ancora "scheletrico").
// AL LANCIO: mettere `noindex = false` + inviare la sitemap in Search Console (vedi PROGETTO.md).
const noindex = true;
// og:image: URL assoluto (Sanity già assoluto; altrimenti risolto sul dominio del sito).
const ogImage = new URL(image ?? '/og-default.png', Astro.site).toString();
const orgLogo = new URL('/icon-512.png', Astro.site).toString();

// Dati strutturati dell'organizzazione (aiuta Google a riconoscere il brand).
const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: siteName,
  url: Astro.site?.toString(),
  logo: orgLogo,
  description,
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />

    {/* hreflang reciproci per ogni lingua + x-default (root, inglese) */}
    {
      (Object.keys(languages) as Array<keyof typeof languages>).map((l) => (
        <link
          rel="alternate"
          hreflang={l}
          href={new URL(localizePath(path, l), Astro.site)}
        />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={new URL(localizePath(path, 'en'), Astro.site)} />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={lang} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} is:inline />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header overlay={overlayHeader} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    {/* Cloudflare Web Analytics — RUM cookieless (nessun banner richiesto) */}
    <script
      is:inline
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "08d50efcbf69414baf876a425b435d6f"}'
    ></script>
  </body>
</html>
