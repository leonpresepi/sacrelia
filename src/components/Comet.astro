---
// Cometa di Betlemme — linea d'autore: stella con scia.
interface Props {
  class?: string;
}
const { class: className = 'w-24 h-24' } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 120 120"
  fill="none"
  stroke="currentColor"
  stroke-linecap="round"
  aria-hidden="true"
  focusable="false"
>
  <!-- scia -->
  <path d="M14 100 L74 40" stroke-width="1.6" opacity="0.95" />
  <path d="M28 106 L82 52" stroke-width="1" opacity="0.5" />
  <path d="M8 86 L66 30" stroke-width="1" opacity="0.5" />
  <!-- stella -->
  <path
    fill="currentColor"
    stroke="none"
    d="M88 18 L91.5 32.5 L106 36 L91.5 39.5 L88 54 L84.5 39.5 L70 36 L84.5 32.5 Z"
  />
</svg>
