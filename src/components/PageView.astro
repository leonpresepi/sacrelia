---
import { toHTML } from '@portabletext/to-html';
import {
  getLangFromUrl,
  useTranslations,
  pickLocale,
  pickLocaleBlocks,
  localizePath,
} from '../i18n/utils';
import { urlForImage } from '../lib/sanity';
import type { Page } from '../lib/queries';
import Divider from './Divider.astro';
import StarMotif from './StarMotif.astro';

interface Props {
  page: Page | null;
  /** Titolo di riserva (dal menu) se la pagina non ha ancora contenuti. */
  defaultTitle: string;
}
const { page, defaultTitle } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const title = (page && pickLocale(page.title, lang)) || defaultTitle;
const lead = page ? pickLocale(page.lead, lang) : '';
const blocks = page ? pickLocaleBlocks(page.body, lang) : [];
const bodyHtml = blocks.length ? toHTML(blocks as never) : '';
const isEmpty = !lead && !bodyHtml;

const heroImg = page?.heroImage?.asset
  ? urlForImage(page.heroImage).width(2200).height(1200).fit('crop').auto('format').url()
  : null;
---

<!-- HERO della sezione -->
<section class="relative min-h-[55vh] flex items-end overflow-hidden">
  {
    heroImg ? (
      <img src={heroImg} alt="" class="absolute inset-0 w-full h-full object-cover" fetchpriority="high" />
    ) : (
      <div class="night-sky absolute inset-0" />
    )
  }
  <div class="absolute inset-0 bg-gradient-to-t from-night-deep/85 via-night-deep/30 to-transparent"></div>

  <div class="relative z-10 px-6 md:px-12 lg:px-16 pb-14 md:pb-20 max-w-4xl text-ivory">
    <div class="flex items-center gap-3 text-gold mb-4">
      <StarMotif class="w-3.5 h-3.5" />
      <span class="text-[11px] uppercase tracking-[0.3em] text-gold-soft/90">{t('site.tagline')}</span>
    </div>
    <h1 class="font-serif text-4xl md:text-6xl leading-tight">{title}</h1>
  </div>
</section>

<!-- CORPO -->
<section class="mx-auto max-w-3xl px-6 py-20 md:py-24">
  {lead && <p class="text-xl md:text-2xl text-ink leading-relaxed font-serif">{lead}</p>}

  {
    bodyHtml ? (
      <div class={`rich text-ink leading-relaxed ${lead ? 'mt-10' : ''}`} set:html={bodyHtml} />
    ) : (
      isEmpty && <p class="text-muted leading-relaxed italic">{t('page.empty')}</p>
    )
  }

  <!-- CTA contatti -->
  <div class="mt-16 text-center">
    <Divider class="mb-10" />
    <a
      href={localizePath('/contact', lang)}
      class="inline-block bg-charcoal text-ivory px-8 py-3 text-sm uppercase tracking-wider hover:bg-ink transition-colors"
    >
      {t('cta.request')}
    </a>
  </div>
</section>

<style>
  .rich :global(p) {
    margin-bottom: 1rem;
  }
  .rich :global(h2),
  .rich :global(h3) {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }
  .rich :global(blockquote) {
    border-left: 2px solid var(--color-bronze);
    padding-left: 1rem;
    font-style: italic;
    color: var(--color-muted);
    margin: 1.5rem 0;
  }
</style>
