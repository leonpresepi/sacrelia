---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageView from '../components/PageView.astro';
import { getPage } from '../lib/queries';
import { getLangFromUrl, useTranslations, pickLocale } from '../i18n/utils';

const slug = 'craftsmanship';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const page = await getPage(slug);

const title = (page && pickLocale(page.title, lang)) || t('nav.craftsmanship');
const description = (page && pickLocale(page.seoDescription, lang)) || t('site.tagline');
---

<BaseLayout title={title} description={description} path={`/${slug}`} overlayHeader>
  <PageView page={page} defaultTitle={t('nav.craftsmanship')} />
</BaseLayout>
