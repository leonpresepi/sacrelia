---
import BaseLayout from '../layouts/BaseLayout.astro';
import StarMotif from '../components/StarMotif.astro';

// La 404 viene servita per qualsiasi percorso non valido, in ogni lingua:
// la teniamo in inglese (lingua di default / x-default) e sobria.
---

<BaseLayout title="Page not found" description="The page you are looking for does not exist." path="/">
  <section class="min-h-[70vh] flex items-center justify-center px-6 py-24 text-center">
    <div>
      <StarMotif class="w-6 h-6 mx-auto text-bronze" />
      <p class="mt-8 font-serif text-6xl md:text-7xl text-charcoal leading-none">404</p>
      <h1 class="mt-6 font-serif text-2xl md:text-3xl text-charcoal">This page could not be found</h1>
      <p class="mt-4 text-muted max-w-md mx-auto">
        The page may have been moved, or the link is no longer valid.
      </p>
      <a
        href="/"
        class="mt-10 inline-block bg-charcoal text-ivory px-8 py-3 text-sm uppercase tracking-wider hover:bg-ink transition-colors"
      >
        Return home
      </a>
    </div>
  </section>
</BaseLayout>
