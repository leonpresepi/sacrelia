# Configurazione Sanity — copia questo file in ".env" e compila i valori.
# Il PROJECT ID si ottiene dopo aver creato il progetto su https://www.sanity.io
# (oppure con: npx sanity projects list)

PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production
PUBLIC_SANITY_API_VERSION=2024-01-01

# Chiave del form contatti — gratuita su https://web3forms.com (Access Key).
# Gli invii arrivano all'email con cui registri la chiave.
PUBLIC_WEB3FORMS_KEY=
